import sympy as sp

def polinomio_lagrange(x_vals, y_vals):
    x = sp.Symbol('x')
    n = len(x_vals)
    P = 0
    
    for i in range(n):
        L_i = 1
        
        for j in range(n):
            if i != j:
                L_i *= (x - x_vals[j]) / (x_vals[i] - x_vals[j])
        
        P += y_vals[i] * L_i
    
    return sp.expand(P)


